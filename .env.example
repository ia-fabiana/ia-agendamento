# Frontend variables (Vite)
# Never place provider secrets (Trinks/Evolution API keys) in frontend envs.

# Backend base URL used as secure proxy for Trinks and Evolution calls.
# Example: http://localhost:3001
VITE_BACKEND_URL=""

# Public identifier only (safe in frontend). Ex: 62260
VITE_TRINKS_ESTABLISHMENT_ID="62260"

# Backend variables (private)
GEMINI_API_KEY=""
TRINKS_API_BASE_URL="https://api.trinks.com/v1"
TRINKS_API_KEY=""
EVOLUTION_API_BASE_URL="https://api.iafabiana.com.br"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""
PORT="3001"